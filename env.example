PGDATABASE=spuncast
PGUSER=postgres
PGPASSWORD=change_me

# --- PostgreSQL host (Option A: one .env for Docker Compose) ---
# Use the Postgres *Compose service name* when ml-score-daemon (or batch jobs) run
# in a container on the *same* network as the database — often ``db``, not localhost.
# Inside a container, ``localhost`` is the container itself, so connections fail.
PG_HOST=db
PGHOST=db
PG_PORT=5432
# When you run ``spuncast-ml export`` / ``train`` on the host with ``venv``, override:
#   PGHOST=localhost PG_HOST=localhost spuncast-ml export
# If Postgres is only on the Docker host (not in compose), try ``host.docker.internal``
# (common on Docker Desktop) or the host IP reachable from the container.

# Upstream dataset contract from Spuncast-Operations
SPUNCAST_ML_SOURCE_VIEW=v_ml_heat_dataset_v1

# Local output locations
SPUNCAST_ML_EXPORT_DIR=./data/exports
SPUNCAST_ML_PROCESSED_DIR=./data/processed
SPUNCAST_ML_MODEL_DIR=./artifacts/models
SPUNCAST_ML_REPORT_DIR=./reports/generated

# --- Live scorer (scripts/score_heat_live.py) ---
# Read-only smoke test: python scripts/score_heat_live.py --dry-run --once --test-heats 100
# SCORE_POLL_INTERVAL_SEC=180
# SCORE_HORIZON_HOURS=8
# SCORE_REMELT_THRESHOLD=0.65
# SCORE_HOLD_THRESHOLD=0.80
# SCORE_CAUTION_THRESHOLD=0.65
# SCORE_ADVISORY_THRESHOLD=0.50
# SCORE_WRITE_ADVISORY_ROWS=0
# SCORE_ENABLE_SHAP=0
# SCORE_SHAP_MAX_HEATS=10

# --- Microsoft Teams webhook notifications ---
# Post a card to Teams for every heat scored. Leave blank to disable.
# TEAMS_WEBHOOK_URL=https://spuncastinc.webhook.office.com/webhookb2/...
# TEAMS_MIN_PROBABILITY=0.0   # 0.0 = notify for all heats; 0.5 = only elevated risk

# --- Weekly automation (scripts/run_pipeline.sh) ---
# SPUNCAST_ML_FEATURE_SET=early_remelt_decision
# SPUNCAST_ML_THRESHOLD=0.5
# SPUNCAST_ML_PROMOTE_MIN_REL=0.05
# SPUNCAST_ML_USE_DOCKER=1

# Documentation: docs/SPUNCAST_ML_CONFIGURATION_GUIDE.md
