PGDATABASE=spuncast
PGUSER=postgres
PGPASSWORD=change_me
# Host-run default: localhost
# Docker-run default: host.docker.internal
PG_HOST=host.docker.internal
PGHOST=host.docker.internal
PG_PORT=5432

# Upstream dataset contract from Spuncast-Operations
SPUNCAST_ML_SOURCE_VIEW=v_ml_heat_dataset_v1

# Local output locations
SPUNCAST_ML_EXPORT_DIR=./data/exports
SPUNCAST_ML_PROCESSED_DIR=./data/processed
SPUNCAST_ML_MODEL_DIR=./artifacts/models
SPUNCAST_ML_REPORT_DIR=./reports/generated

# Optional: when running against a local host process instead of Docker,
# switch PGHOST / PG_HOST back to localhost.
