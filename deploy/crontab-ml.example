# Example cron entries for Spuncast-ML (host paths should match your deployment).
# Weekly retrain (Monday 02:00 UTC) — uses docker-compose when SPUNCAST_ML_USE_DOCKER=1.
0 2 * * 1 cd /opt/Spuncast-Operations/Spuncast-ML-main && SPUNCAST_ML_USE_DOCKER=1 bash scripts/run_pipeline.sh >> reports/cron_training.log 2>&1

# Daily drift report (06:00 UTC)
0 6 * * * cd /opt/Spuncast-Operations/Spuncast-ML-main && docker compose run --rm spuncast-ml monitor-drift --feature-set early_remelt_decision >> reports/cron_drift.log 2>&1

# Live scorer (prefer systemd or compose restart policy; this is a simple keep-alive example)
# */5 * * * * docker compose -f /opt/Spuncast-Operations/Spuncast-ML-main/docker-compose.yml --profile daemon up -d ml-score-daemon
